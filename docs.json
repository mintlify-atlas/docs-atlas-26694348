            "pages": [
              "concepts/gherkin-basics",
              "concepts/step-definitions",
              "concepts/hooks",
              "concepts/data-tables",
              "concepts/tags"
            ]
          },
          {
            "group": "Running Tests",
            "pages": [
              "runners/junit5",
              "runners/junit4",
              "runners/testng",
              "runners/parallel-execution"
            ]
          },
          {
            "group": "Dependency Injection",
            "pages": [
              "di/overview",
              "di/spring",
              "di/guice",
              "di/picocontainer",
              "di/cdi"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Configuration",
            "pages": [
              "reference/configuration-options",
              "reference/cucumber-expressions",
              "reference/doc-strings"
            ]
          },
          {
            "group": "Plugins & Reporting",
            "pages": [
              "reference/built-in-plugins",
              "reference/custom-plugins"
            ]
          },
          {
            "group": "Migration",
            "pages": [
              "reference/upgrading",
              "reference/changelog"
            ]
          }
