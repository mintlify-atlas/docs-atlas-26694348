{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Cucumber JVM",
  "theme": "palm",
  "colors": {
    "primary": "#23d96b",
    "light": "#1c8f5b",
    "dark": "#fb740d"
  },
  "favicon": "https://media.brand.dev/928d8e9d-8af4-45fc-8d2b-efe67290e327.jpg",
  "logo": {
    "light": "https://media.brand.dev/bc88b594-f1ab-4f74-a33c-d48101d6a51b.png",
    "dark": "https://media.brand.dev/bc88b594-f1ab-4f74-a33c-d48101d6a51b.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/cucumber/cucumber-jvm"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/cucumber/cucumber-jvm"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
