{
  "projectType": "framework",
  "projectName": "Cucumber JVM",
  "projectDescription": "A BDD testing framework for the JVM that lets teams write automated tests in plain Gherkin language and execute them with Java, Kotlin, and popular test runners like JUnit 5 and TestNG.",
  "theme": "palm",
  "primaryColor": "#23d96b",
